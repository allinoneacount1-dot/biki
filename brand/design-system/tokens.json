{
  "$schema": "BIKI design system v1.0.0",
  "description": "the source of truth for biki's design system. reference these values — never invent.",

  "color": {
    "ink": {
      "primary": "#0F1012",
      "soft": "#1A1C20",
      "mute": "#6B6F78"
    },
    "bone": {
      "primary": "#F4F1EA",
      "soft": "#EAE6DD",
      "mute": "#D8D3C8"
    },
    "ochre": {
      "primary": "#9C6B2E",
      "deep": "#7A4F22",
      "soft": "#D4A574"
    },
    "semantic": {
      "surface": {
        "bone": "#F4F1EA",
        "bone-soft": "#EAE6DD",
        "ink": "#0F1012",
        "ink-soft": "#1A1C20"
      },
      "border": {
        "on-bone": "#D8D3C8",
        "on-ink": "#1A1C20"
      },
      "text": {
        "on-bone": "#0F1012",
        "on-bone-mute": "#6B6F78",
        "on-ink": "#F4F1EA",
        "on-ink-mute": "#D8D3C8"
      },
      "accent": {
        "default": "#9C6B2E",
        "hover": "#7A4F22",
        "tint": "#D4A574"
      }
    }
  },

  "typography": {
    "font": {
      "sans": "'Inter', 'SF Pro Display', system-ui, -apple-system, sans-serif",
      "mono": "'JetBrains Mono', 'IBM Plex Mono', ui-monospace, monospace"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "tracking": {
      "tight": "-0.02em",
      "snug": "-0.01em",
      "normal": "0",
      "wide": "0.04em",
      "wider": "0.08em",
      "widest": "0.16em"
    },
    "size": {
      "display-xl": "72px",
      "display-lg": "56px",
      "display-md": "40px",
      "heading-lg": "28px",
      "heading-md": "22px",
      "body-lg": "18px",
      "body": "16px",
      "body-sm": "14px",
      "caption": "12px",
      "mono": "13px"
    },
    "leading": {
      "display-xl": 1.05,
      "display-lg": 1.1,
      "display-md": 1.15,
      "heading-lg": 1.25,
      "heading-md": 1.35,
      "body-lg": 1.55,
      "body": 1.6,
      "body-sm": 1.55,
      "caption": 1.4,
      "mono": 1.5
    }
  },

  "spacing": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "6": "24px",
    "8": "32px",
    "12": "48px",
    "16": "64px",
    "24": "96px",
    "32": "128px",
    "48": "192px"
  },

  "radius": {
    "none": "0",
    "xs": "2px",
    "sm": "4px",
    "full": "9999px"
  },

  "container": {
    "sm": "640px",
    "md": "800px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1440px"
  },

  "motion": {
    "duration": {
      "instant": "80ms",
      "fast": "150ms",
      "base": "220ms",
      "slow": "400ms"
    },
    "ease": {
      "out": "cubic-bezier(0.16, 1, 0.3, 1)",
      "in-out": "cubic-bezier(0.4, 0, 0.2, 1)"
    }
  },

  "grain": {
    "opacity": 0.025,
    "blend": "multiply"
  },

  "z-index": {
    "base": 0,
    "raised": 10,
    "overlay": 100,
    "modal": 1000
  }
}